{
  "version": 2,
  "builds": [
    { "src": "**/*", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/styles.css", "dest": "/styles.css" },
    { "src": "/nav.js", "dest": "/nav.js" },
    { "src": "/public/(.*)", "dest": "/public/$1" },
    { "src": "/images/(.*)", "dest": "/images/$1" },
    { "src": "/(.*)\\.html", "dest": "/$1.html" },
    { "src": "/", "dest": "/index.html" }
  ]
}
